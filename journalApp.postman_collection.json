{
  "info": {
    "name": "Journal App",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "userName",
      "value": "testUser",
      "type": "string"
    },
    {
      "key": "journalId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/User", "host": ["{{baseUrl}}"], "path": ["User"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{userName}}\",\n  \"password\": \"pass123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/User", "host": ["{{baseUrl}}"], "path": ["User"] }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/User/{{userName}}",
              "host": ["{{baseUrl}}"],
              "path": ["User", "{{userName}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{userName}}\",\n  \"password\": \"newpass456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Journal",
      "item": [
        {
          "name": "Create Journal Entry",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('journalId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/Journal/{{userName}}",
              "host": ["{{baseUrl}}"],
              "path": ["Journal", "{{userName}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Entry\",\n  \"content\": \"Today was a good day\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Entries for User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/Journal/{{userName}}",
              "host": ["{{baseUrl}}"],
              "path": ["Journal", "{{userName}}"]
            }
          }
        },
        {
          "name": "Get Entry by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/Journal/id/{{journalId}}",
              "host": ["{{baseUrl}}"],
              "path": ["Journal", "id", "{{journalId}}"]
            }
          }
        },
        {
          "name": "Update Journal Entry",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/Journal/id/{{userName}}/{{journalId}}",
              "host": ["{{baseUrl}}"],
              "path": ["Journal", "id", "{{userName}}", "{{journalId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"content\": \"Updated content here\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Journal Entry",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/Journal/delete/{{userName}}/{{journalId}}",
              "host": ["{{baseUrl}}"],
              "path": ["Journal", "delete", "{{userName}}", "{{journalId}}"]
            }
          }
        }
      ]
    }
  ]
}
